---
extends: default
ignore: |
  .venv/
rules:
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  comments-indentation: disable
  document-start: disable
  indentation: disable
  line-length: disable
  truthy: disable
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
